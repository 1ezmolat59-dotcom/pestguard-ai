# PestGuard AI — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Server Configuration ─────────────────────────────────────────────────────
PORT=8888

# ── AI Configuration (Optional) ──────────────────────────────────────────────
# Leave blank to run in Demo Mode (rule-based parser, no API cost)
# Add your OpenAI key to enable GPT-4o natural language parsing
OPENAI_API_KEY=

# ── Company Branding ──────────────────────────────────────────────────────────
# Your company name shown on PDF audit reports
COMPANY_NAME=Your Pest Control Company

# ── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite database file (defaults to ./pestguard.db in app directory)
# DB_PATH=/path/to/custom/pestguard.db

# ── Reports ───────────────────────────────────────────────────────────────────
# Directory where PDF audit reports are saved (defaults to ./reports/)
# REPORTS_DIR=/path/to/reports/

# ── Email Alerts (Optional) ───────────────────────────────────────────────────
# ALERT_EMAIL=owner@yourcompany.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@pestguard.ai
